# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/hospital_queue_system
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/hospital_queue_system
MONGODB_URI=mongodb://localhost:27017/hospital_queue_system

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use a long, random, secret string in production (min 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend URL ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=replace_with_a_random_cookie_secret

# ─── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# To use Gmail:
#   1. Enable 2-Factor Authentication in your Google Account
#   2. Go to Security → App passwords → Generate password for "Mail"
#   3. Use the 16-character app password below (NOT your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=MediQueue <your_email@gmail.com>

# ─── Dev Flags ────────────────────────────────────────────────────────────────
# Skip email verification check during development (set false in production)
SKIP_EMAIL_VERIFY=true

# ─── Stripe (Optional — payment feature) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Admin Seed Credentials ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=Admin@123456
