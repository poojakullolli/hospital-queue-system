{
  "name": "hospital-queue-backend",
  "version": "1.0.0",
  "description": "Hospital Smart Appointment and Live Queue Management System — Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/seed/seed.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/setup.js",
    "globalTeardown": "./tests/teardown.js",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/src/seed/"
    ]
  },
  "keywords": [
    "hospital",
    "queue",
    "appointment",
    "healthcare",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "express-validator": "^7.3.2",
    "firebase-admin": "^14.2.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.8.0",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.1"
  }
}
